<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.TravelMate" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#9C27B0</item>
        <item name="colorPrimaryVariant">#7B1FA2</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#FF5722</item>
        <item name="colorSecondaryVariant">#FF5722</item>
        <item name="colorOnSecondary">#FFFFFF</item>

        <!-- Fondo morado clarito -->
        <item name="android:windowBackground">#F0E6FF</item>
        <item name="android:statusBarColor">#7B1FA2</item>

        <!-- TEXTOS PRINCIPALES EN NEGRO (legibles) -->
        <item name="android:textColorPrimary">#1A1A1A</item>
        <item name="android:textColorSecondary">#4A4A4A</item>

        <!-- Texto de títulos (Toolbar, ActionBar) -->
        <item name="android:textColorPrimaryInverse">#1A1A1A</item>

        <!-- Estilo de texto más grueso para toda la app -->
        <item name="android:textViewStyle">@style/BoldTextView</item>

        <!-- Color del botón ATRÁS (fondo visible) -->
        <item name="android:navigationBarColor">#E0D0F5</item>
    </style>

    <style name="BoldTextView" parent="Widget.AppCompat.TextView">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
    </style>
</resources>