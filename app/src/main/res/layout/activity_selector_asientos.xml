<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="?android:attr/windowBackground">

    <Button
        android:id="@+id/btnAtras"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="← Atrás"
        android:textSize="14sp"
        android:padding="12dp"
        android:layout_marginTop="32dp"
        android:backgroundTint="@color/primary"
        android:textColor="@color/white"
        app:cornerRadius="20dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Selecciona tu asiento"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"
        android:gravity="center"
        android:layout_marginTop="24dp"/>

    <TextView
        android:id="@+id/tvInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cargando mapa de asientos..."
        android:textAlignment="center"
        android:layout_marginTop="16dp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorSecondary"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp">

        <LinearLayout
            android:id="@+id/llMapaAsientos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <TextView
        android:id="@+id/tvAsientoSeleccionado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Asiento seleccionado: Ninguno"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/success"
        android:layout_marginTop="16dp"/>

    <Button
        android:id="@+id/btnConfirmarAsiento"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Confirmar asiento (+3€ si cambias)"
        android:backgroundTint="@color/success"
        android:textColor="@color/white"
        android:layout_marginTop="16dp"
        app:cornerRadius="20dp"/>

</LinearLayout>